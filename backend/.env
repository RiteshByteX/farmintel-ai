# ============================================
# FarmIntel AI - Environment Configuration
# ============================================

# ============================================
# Flask Application Settings
# ============================================
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Secret key for session management (CHANGE THIS IN PRODUCTION!)
SECRET_KEY=farmintel-super-secret-key-change-in-production-2024

# ============================================
# File Upload Settings
# ============================================
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216  # 16MB in bytes
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,bmp,webp

# ============================================
# Model Configuration
# ============================================
MODEL_PATH=models/plant_disease_model.h5
MODEL_METADATA_PATH=models/model_metadata.json
IMG_SIZE=224,224
BATCH_SIZE=32
CONFIDENCE_THRESHOLD=0.5

# ============================================
# Training Parameters
# ============================================
EPOCHS=50
LEARNING_RATE=0.001
TRAIN_SPLIT=0.7
VAL_SPLIT=0.2
TEST_SPLIT=0.1

# ============================================
# Weather API Configuration (OpenWeatherMap)
# ============================================
# Sign up at https://openweathermap.org/api to get a free API key
WEATHER_API_KEY=
WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5
WEATHER_API_TIMEOUT=10
WEATHER_UNITS=metric
WEATHER_LANGUAGE=en
DEFAULT_CITY=Mumbai
DEFAULT_COUNTRY=IN

# ============================================
# Database / Storage Settings
# ============================================
DATABASE_FOLDER=database
HISTORY_FILE=database/history.json
USERS_FILE=database/users.json
REPORTS_FOLDER=reports

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ============================================
# CORS Settings (Cross-Origin Resource Sharing)
# ============================================
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:5000,http://127.0.0.1:5000
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization,X-Requested-With

# ============================================
# Cache Settings
# ============================================
CACHE_TYPE=simple
CACHE_DEFAULT_TIMEOUT=300
WEATHER_CACHE_DURATION=1800  # 30 minutes in seconds

# ============================================
# Email Configuration (Optional - for notifications)
# ============================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# ============================================
# Rate Limiting (Optional)
# ============================================
RATELIMIT_ENABLED=False
RATELIMIT_DEFAULT=100/hour
RATELIMIT_STORAGE_URL=memory://

# ============================================
# Security Settings (Production)
# ============================================
# SESSION_COOKIE_SECURE=True
# SESSION_COOKIE_HTTPONLY=True
# SESSION_COOKIE_SAMESITE=Lax
# PERMANENT_SESSION_LIFETIME=86400  # 24 hours in seconds

# ============================================
# Development Settings
# ============================================
DEBUG_TOOLBAR_ENABLED=False
TESTING=False

# ============================================
# App Information
# ============================================
APP_NAME=FarmIntel AI
APP_VERSION=1.0.0
APP_DESCRIPTION=AI-powered crop disease detection and farm advisory system
APP_AUTHOR=FarmIntel AI Team